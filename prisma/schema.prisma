datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String        @id @default(cuid())
  email       String        @unique
  password    String
  name        String?
  employeeId  String?
  role        String        @default("EMPLOYEE")
  createdAt   DateTime      @default(now())

  attendances Attendance[]
}


model Attendance {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  status    String

  user      User     @relation(fields: [userId], references: [id])
}
